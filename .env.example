# Production-required database configuration.
# Must be a PostgreSQL URL with host, database, username, password, and SSL intent.
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Currently unused: fallback token support is not implemented.
GITHUB_TOKEN=your_github_personal_access_token

# Production-required GitHub OAuth app credentials.
# Create one at: https://github.com/settings/developers
# Local callback URL: http://localhost:3000/api/auth/callback/github
# Production callback URL must use your HTTPS BETTER_AUTH_URL.
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Optional GitHub API base URL. Production values must use HTTPS.
GITHUB_BASE_URL=https://api.github.com

# Production-required Better Auth configuration.
# BETTER_AUTH_SECRET must be at least 32 characters and not this placeholder.
# BETTER_AUTH_URL must be HTTPS in production and must not use localhost/loopback.
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Currently unused: custom repository file loading is not implemented.
REPOSITORIES_FILE=./repositories.json
