# PlanetScale Postgres Database Configuration
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# GitHub API Configuration
# Optional: Fallback token for unauthenticated requests
GITHUB_TOKEN=your_github_personal_access_token

# GitHub OAuth App Credentials (Required for authentication)
# Create one at: https://github.com/settings/developers
# Callback URL should be: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub API Base URL
GITHUB_BASE_URL=https://api.github.com

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Optional: Custom repositories file path
REPOSITORIES_FILE=./repositories.json
