# Ingestor-specific environment. Copy to apps/ingestor/.env for local runs.

# Shared PostgreSQL database used by apps/web and apps/ingestor.
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# GitHub token used for higher REST API limits and GraphQL discussions access.
GITHUB_TOKEN=github_pat_or_token
GITHUB_BASE_URL=https://api.github.com

# Temporal connection.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=solana-changelog-ingestor
TEMPORAL_SCHEDULE_ID=solana-changelog-ingestor
SYNC_INTERVAL=1 hour
